{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/telegram/**/*.ts",
    "src/commands/telegram/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
