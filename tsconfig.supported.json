{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "rootDir": ".",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "files": [
    "scripts/check-version-truth.ts",
    "scripts/system-check.ts",
    "src/services/api/fallbackChain.ts",
    "src/services/api/providerConfig.ts",
    "src/services/memory/memoryStore.ts",
    "src/services/usage/usageStore.ts",
    "src/services/voice/diagnostics.ts",
    "src/services/voice/exec.ts",
    "src/services/voice/stt.ts",
    "src/services/voice/tts.ts",
    "src/services/voice/types.ts",
    "src/services/voice/voiceMode.ts",
    "src/services/voice/voiceService.ts",
    "src/utils/freeclaudeConfig.ts",
    "src/utils/providerProfile.ts",
    "src/utils/providerRecommendation.ts",
    "src/services/vault/vaultStore.ts",
    "src/commands/vault/vault.ts",
    "src/services/memory/decay.ts",
    "src/services/memory/autoRemember.ts",
    "src/services/memory/autoIndex.ts",
    "src/services/memory/consolidation.ts",
    "src/services/heartbeat/heartbeat.ts",
    "src/services/agents/agentBridge.ts",
    "src/services/agents/agentProtocol.ts",
    "src/services/context/compactor.ts",
    "src/services/context/budgetTracker.ts",
    "src/services/context/degradation.ts",
    "src/services/context/providerWindows.ts",
    "src/services/tasks/protocol/types.ts",
    "src/services/tasks/protocol/taskProtocol.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
