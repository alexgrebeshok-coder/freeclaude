{
  "name": "freeclaude-desktop",
  "productName": "FreeClaude",
  "version": "3.4.0",
  "description": "FreeClaude Desktop - AI-powered coding assistant",
  "author": "FreeClaude",
  "main": ".vite/build/bootstrap.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "build": "electron-forge make",
    "make": "electron-forge make",
    "package": "electron-forge package",
    "publish": "electron-forge publish",
    "open:app": "node scripts/open-packaged.cjs",
    "launch": "npm run install:mac",
    "install:mac": "npm run package && node scripts/install-mac.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "version:sync": "node scripts/sync-version.cjs",
    "version:sync:check": "node scripts/sync-version.cjs --check",
    "cask:generate": "node scripts/generate-cask.cjs"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-dmg": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.5.0",
    "@electron-forge/plugin-vite": "^7.5.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "electron": "^32.3.3",
    "eslint": "^9.18.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "config": {}
}
